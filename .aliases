# Aliases
alias prettyjson='python -m json.tool'
alias adb-list='adb shell pm list packages -3'
alias brew="env PATH=${PATH//$(pyenv root)\/shims:/} brew"
alias brewup='brew update; brew upgrade; brew cleanup; brew doctor'
alias speedtest='curl -o /dev/null http://speedtest.wdc01.softlayer.com/downloads/test10.zip'
alias reload='source ~/.zshrc'
alias placonaup='docker-compose up nginx-proxy placona jekyll'
alias cat="bat"
alias ls="ls -lSrhat"
alias ip="echo Your ip is; dig +short myip.opendns.com @resolver1.opendns.com;"
alias du="du -sh * | sort -h"
alias tailscale="/Applications/Tailscale.app/Contents/MacOS/Tailscale"

# Directory shortcuts
alias p='cd ~/Projects/'
alias d='cd ~/Downloads/'
alias dev='cd ~/Projects/DevRelWork'
alias o='cd "$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Obsidian Vault"'

# DevRel tmux session
function devrel() {
  cd "$HOME/Projects/DevRelWork"
  printf '\e]0;🔵 DevRel\a'
  tmux attach -t devrel 2>/dev/null || \
  tmux new-session -d -s devrel \; \
    set-option -t devrel status-style bg=blue,fg=black \; \
    rename-window "🔵 DevRel"
  tmux attach -t devrel
}

# MentionDrop tmux session
function mentiondrop() {
  printf '\e]0;🟣 MentionDrop\a'
  mosh mplacona@100.102.111.19 -- tmux new -As mentiondrop
}

# VPS tmux session + SSH
function vps() {
  printf '\e]0;🔴 VPS\a'
  tmux attach -t vps 2>/dev/null || \
  tmux new-session -d -s vps \; \
    set-option -t vps status-style bg=red,fg=white \; \
    rename-window "🔴 VPS"
  tmux attach -t vps
  ssh mplacona@100.102.111.19
}

# Remote sessions via mosh (attach if exists, create if not)
function clientwork() {
  printf '\e]0;🟢 ClientWork\a'
  mosh mplacona@100.102.111.19 -- tmux new -As clientwork
}

function hermes() {
  printf '\e]0;⚫ Hermes\a'
  mosh mplacona@100.102.111.19 -- tmux new -As hermes
}

